datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id          String    @id
  shop        String
  state       String
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String
  userId      BigInt?
}

model Ticket {
  id          Int      @id @default(autoincrement())
  customer    String
  email       String
  message     String
  status      String   @default("open")
  channel     String
  createdAt   DateTime @default(now())
}
